<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>EventSuite — Pagos y Roles</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css"/>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: system-ui, sans-serif; background: #f4f4f0; }
.app { display: flex; height: 100vh; }
.sidebar { width: 200px; background: #fff; border-right: 0.5px solid #ddd; padding: 16px 0; display: flex; flex-direction: column; gap: 2px; flex-shrink: 0; }
.sidebar-logo { padding: 0 16px 16px; border-bottom: 0.5px solid #eee; margin-bottom: 8px; }
.sidebar-logo p { font-size: 13px; font-weight: 500; color: #111; }
.sidebar-logo span { font-size: 11px; color: #888; }
.nav-item { display: flex; align-items: center; gap: 8px; padding: 8px 16px; cursor: pointer; font-size: 13px; color: #666; transition: all 0.15s; }
.nav-item:hover { background: #f5f5f5; color: #111; }
.nav-item.active { background: #e8f0fe; color: #1a56db; font-weight: 500; }
.nav-item i { font-size: 16px; }
.nav-section { padding: 12px 16px 4px; font-size: 10px; font-weight: 500; color: #aaa; text-transform: uppercase; letter-spacing: 0.08em; }
.main { flex: 1; overflow-y: auto; }
.topbar { background: #fff; border-bottom: 0.5px solid #ddd; padding: 12px 24px; display: flex; align-items: center; justify-content: space-between; }
.topbar h1 { font-size: 15px; font-weight: 500; color: #111; }
.content { padding: 20px 24px; }
.page { display: none; }
.page.active { display: block; }
.card { background: #fff; border: 0.5px solid #ddd; border-radius: 12px; padding: 16px; margin-bottom: 16px; }
.card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
.card-title { font-size: 13px; font-weight: 500; color: #111; }
.two-col { display: grid; grid-template-columns: minmax(0,1fr) minmax(0,1fr); gap: 16px; }
table { width: 100%; border-collapse: collapse; font-size: 12px; table-layout: fixed; }
th { font-size: 11px; font-weight: 500; color: #666; text-align: left; padding: 6px 6px; border-bottom: 0.5px solid #eee; overflow: hidden; text-overflow: ellipsis; }
td { padding: 7px 6px; border-bottom: 0.5px solid #eee; color: #111; vertical-align: middle; overflow: hidden; text-overflow: ellipsis; }
tr:last-child td { border-bottom: none; }
.badge { display: inline-flex; align-items: center; padding: 2px 8px; border-radius: 8px; font-size: 11px; font-weight: 500; white-space: nowrap; }
.badge-success { background: #d1fae5; color: #065f46; }
.alert { display: flex; align-items: flex-start; gap: 10px; padding: 10px 14px; border-radius: 8px; margin-bottom: 10px; font-size: 12px; }
.alert-info { background: #dbeafe; color: #1e40af; border: 0.5px solid #93c5fd; }
.alert-warning { background: #fef3c7; color: #92400e; border: 0.5px solid #fcd34d; }
.alert i { margin-top: 1px; flex-shrink: 0; }
.form-grid { display: grid; grid-template-columns: minmax(0,1fr) minmax(0,1fr); gap: 12px; }
.form-group { display: flex; flex-direction: column; gap: 4px; }
.form-group label { font-size: 11px; font-weight: 500; color: #666; }
.form-group input, .form-group select, .form-group textarea { font-size: 13px; width: 100%; padding: 8px 10px; border: 0.5px solid #ddd; border-radius: 8px; outline: none; font-family: inherit; }
.form-group input:focus, .form-group select:focus { border-color: #93c5fd; }
.form-full { grid-column: 1 / -1; }
.btn { padding: 7px 14px; font-size: 12px; cursor: pointer; border-radius: 8px; font-weight: 500; display: inline-flex; align-items: center; gap: 6px; border: 0.5px solid #ddd; background: #fff; color: #111; font-family: inherit; }
.btn:hover { background: #f5f5f5; }
.btn-primary { background: #dbeafe; color: #1e40af; border-color: #93c5fd; }
.btn-primary:hover { background: #bfdbfe; }
.service-row { display: flex; align-items: center; gap: 10px; padding: 8px 0; border-bottom: 0.5px solid #eee; }
.service-row:last-child { border-bottom: none; }
.service-row input[type="checkbox"] { width: 16px; height: 16px; flex-shrink: 0; }
.service-name { flex: 1; font-size: 13px; color: #111; }
.service-price { font-size: 12px; color: #666; min-width: 90px; text-align: right; }
.summary-row { display: flex; justify-content: space-between; padding: 6px 0; font-size: 13px; color: #666; }
.summary-row.total { font-weight: 500; font-size: 16px; color: #111; border-top: 0.5px solid #eee; padding-top: 10px; margin-top: 6px; }
.permission-grid { display: grid; grid-template-columns: minmax(0,1.6fr) repeat(4, minmax(0,1fr)); gap: 0; font-size: 12px; }
.permission-grid .ph { font-weight: 500; color: #666; font-size: 11px; padding: 8px 6px; border-bottom: 0.5px solid #eee; text-align: center; }
.permission-grid .ph:first-child { text-align: left; }
.permission-grid .pmod { padding: 8px 6px; border-bottom: 0.5px solid #eee; color: #111; display: flex; align-items: center; }
.permission-grid .pcell { padding: 8px 6px; border-bottom: 0.5px solid #eee; display: flex; align-items: center; justify-content: center; }
.permission-grid .pcell input { width: 16px; height: 16px; }
.role-pill { display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 20px; font-size: 11px; cursor: pointer; border: 0.5px solid #ddd; background: #fff; color: #666; }
.role-pill.active { background: #dbeafe; color: #1e40af; border-color: #93c5fd; }
.filters { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 12px; }
.status-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; margin-right: 6px; }
</style>
</head>
<body>
<div class="app">
  <div class="sidebar">
    <div class="sidebar-logo">
      <p>EventSuite</p>
      <span>Pagos &amp; roles</span>
    </div>
    <span class="nav-section">Pagos</span>
    <div class="nav-item active" onclick="showPage('cotizacion')"><i class="ti ti-file-invoice"></i> Cotizaciones</div>
    <div class="nav-item" onclick="showPage('costos')"><i class="ti ti-calculator"></i> Costo del evento</div>
    <div class="nav-item" onclick="showPage('abonos')"><i class="ti ti-receipt"></i> Abonos y estados de cuenta</div>
    <span class="nav-section">Administración</span>
    <div class="nav-item" onclick="showPage('roles')"><i class="ti ti-users"></i> Roles y permisos</div>
  </div>

  <div class="main">
    <div id="page-cotizacion" class="page active">
      <div class="topbar"><h1>Cotización dinámica — r.f / r.i 4.1</h1></div>
      <div class="content">
        <div class="alert alert-info"><i class="ti ti-clock"></i><div>Cotización <strong>COT-2026-014</strong> — Creada: 21/06/2026 · Vence: <strong>06/07/2026</strong> (validez automática de 15 días calendario).</div></div>
        <div class="two-col">
          <div class="card">
            <div class="card-header"><span class="card-title">Servicios disponibles</span></div>
            <div class="service-row"><input type="checkbox" checked onchange="calcCotizacion()" data-price="3500000" /><span class="service-name">Salón Principal</span><span class="service-price">$3.500.000</span></div>
            <div class="service-row"><input type="checkbox" checked onchange="calcCotizacion()" data-price="2800000" /><span class="service-name">Catering (por evento)</span><span class="service-price">$2.800.000</span></div>
            <div class="service-row"><input type="checkbox" onchange="calcCotizacion()" data-price="900000" /><span class="service-name">Música / DJ</span><span class="service-price">$900.000</span></div>
            <div class="service-row"><input type="checkbox" onchange="calcCotizacion()" data-price="450000" /><span class="service-name">Iluminación decorativa</span><span class="service-price">$450.000</span></div>
            <div class="service-row"><input type="checkbox" onchange="calcCotizacion()" data-price="600000" /><span class="service-name">Fotografía y video</span><span class="service-price">$600.000</span></div>
            <div class="form-group form-full" style="margin-top:10px;">
              <label>Descuento (%)</label>
              <input type="number" id="descuento" min="0" max="100" value="0" onchange="calcCotizacion()" />
            </div>
          </div>
          <div class="card">
            <div class="card-header"><span class="card-title">Resumen de cotización</span></div>
            <div class="summary-row"><span>Subtotal</span><span id="sub-cot">$0</span></div>
            <div class="summary-row"><span>Descuento</span><span id="desc-cot">-$0</span></div>
            <div class="summary-row"><span>IVA (19%)</span><span id="iva-cot">$0</span></div>
            <div class="summary-row total"><span>Total (COP)</span><span id="total-cot">$0</span></div>
            <button class="btn btn-primary" style="margin-top:14px;width:100%;justify-content:center;"><i class="ti ti-file-check"></i> Generar cotización</button>
          </div>
        </div>
      </div>
    </div>

    <div id="page-costos" class="page">
      <div class="topbar"><h1>Costo total del evento — r.f / r.i 4.2</h1></div>
      <div class="content">
        <div class="card">
          <div class="card-header"><span class="card-title">Cálculo: (Valor paquete × invitados) + adicionales - abonos</span></div>
          <div class="form-grid">
            <div class="form-group"><label>Valor del paquete por invitado (COP)</label><input type="number" id="valorPaquete" value="85000" onchange="calcCosto()" /></div>
            <div class="form-group"><label>Número de invitados</label><input type="number" id="numInv" value="150" onchange="calcCosto()" /></div>
            <div class="form-group"><label>Servicios adicionales — DJ (COP)</label><input type="number" id="addDJ" value="900000" onchange="calcCosto()" /></div>
            <div class="form-group"><label>Servicios adicionales — Luces (COP)</label><input type="number" id="addLuces" value="450000" onchange="calcCosto()" /></div>
            <div class="form-group"><label>Total de abonos realizados (COP)</label><input type="number" id="totalAbonos" value="5000000" onchange="calcCosto()" /></div>
          </div>
          <div style="margin-top:16px;">
            <div class="summary-row"><span>Paquete (valor × invitados)</span><span id="costo-paquete">$0</span></div>
            <div class="summary-row"><span>Adicionales (DJ + Luces)</span><span id="costo-adic">$0</span></div>
            <div class="summary-row"><span>Subtotal evento</span><span id="costo-subtotal">$0</span></div>
            <div class="summary-row"><span>Total abonado</span><span id="costo-abonos">-$0</span></div>
            <div class="summary-row total"><span>Saldo pendiente</span><span id="costo-saldo" style="color:#991b1b;">$0</span></div>
          </div>
          <button class="btn btn-primary" style="margin-top:14px;"><i class="ti ti-file-invoice"></i> Generar factura / comprobante</button>
        </div>
      </div>
    </div>

    <div id="page-abonos" class="page">
      <div class="topbar"><h1>Abonos y estado de cuenta — r.f / r.i 4.1</h1></div>
      <div class="content">
        <div class="two-col">
          <div class="card">
            <div class="card-header"><span class="card-title">Registrar abono</span></div>
            <div class="form-grid">
              <div class="form-group form-full"><label>ID del evento / cotización</label><input type="text" value="COT-2026-014" /></div>
              <div class="form-group"><label>Valor abonado (COP)</label><input type="number" placeholder="0" /></div>
              <div class="form-group"><label>Fecha</label><input type="date" value="2026-06-21" /></div>
              <div class="form-group form-full"><label>Método de pago</label><select><option>Transferencia</option><option>Efectivo</option></select></div>
            </div>
            <button class="btn btn-primary" style="margin-top:14px;"><i class="ti ti-receipt"></i> Registrar y generar comprobante PDF</button>
          </div>
          <div class="card">
            <div class="card-header"><span class="card-title">Estado de cuenta — COT-2026-014</span></div>
            <div class="summary-row"><span>Costo total del evento</span><span>$13.150.000</span></div>
            <div class="summary-row"><span>Total abonado</span><span>$5.000.000</span></div>
            <div class="summary-row total"><span>Saldo pendiente</span><span style="color:#991b1b;">$8.150.000</span></div>
          </div>
        </div>
        <div class="card">
          <div class="card-header"><span class="card-title">Historial de abonos</span></div>
          <table>
            <thead><tr><th>ID abono</th><th>Valor</th><th>Fecha</th><th>Método</th><th>Comprobante</th></tr></thead>
            <tbody>
              <tr><td>AB-0041</td><td>$3.000.000</td><td>02/06/26</td><td>Transferencia</td><td><span class="badge badge-success">PDF #0041</span></td></tr>
              <tr><td>AB-0039</td><td>$2.000.000</td><td>18/05/26</td><td>Efectivo</td><td><span class="badge badge-success">PDF #0039</span></td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div id="page-roles" class="page">
      <div class="topbar"><h1>Mantenimiento de roles — r.f / r.i 5.1</h1></div>
      <div class="content">
        <div class="filters">
          <span class="role-pill active" onclick="selectRole(this,'Administrador')">Administrador</span>
          <span class="role-pill" onclick="selectRole(this,'Coordinador de eventos')">Coordinador de eventos</span>
          <span class="role-pill" onclick="selectRole(this,'Responsable de bodega')">Responsable de bodega</span>
          <span class="role-pill" onclick="selectRole(this,'Cajero')">Cajero</span>
        </div>
        <div class="card">
          <div class="card-header">
            <span class="card-title">Matriz de permisos — <span id="rol-actual">Administrador</span></span>
            <div style="display:flex;align-items:center;gap:8px;">
              <span style="font-size:12px;color:#666;">Estado del empleado</span>
              <select id="estadoEmpleado" onchange="toggleEstado()"><option>Activo</option><option>Inactivo</option></select>
            </div>
          </div>
          <div id="estado-alert" style="display:none;" class="alert alert-warning"><i class="ti ti-lock"></i><span>Empleado inactivo: el acceso a todos los módulos ha sido restringido automáticamente.</span></div>
          <div class="permission-grid" id="permGrid">
            <div class="ph">Módulo</div><div class="ph">Crear</div><div class="ph">Consultar</div><div class="ph">Modificar</div><div class="ph">Eliminar</div>
            <div class="pmod">Reservas</div><div class="pcell"><input type="checkbox" checked/></div><div class="pcell"><input type="checkbox" checked/></div><div class="pcell"><input type="checkbox" checked/></div><div class="pcell"><input type="checkbox" checked/></div>
            <div class="pmod">Inventario</div><div class="pcell"><input type="checkbox" checked/></div><div class="pcell"><input type="checkbox" checked/></div><div class="pcell"><input type="checkbox" checked/></div><div class="pcell"><input type="checkbox" checked/></div>
            <div class="pmod">Pagos / cotizaciones</div><div class="pcell"><input type="checkbox" checked/></div><div class="pcell"><input type="checkbox" checked/></div><div class="pcell"><input type="checkbox" checked/></div><div class="pcell"><input type="checkbox" checked/></div>
            <div class="pmod">Reportes de baja</div><div class="pcell"><input type="checkbox" checked/></div><div class="pcell"><input type="checkbox" checked/></div><div class="pcell"><input type="checkbox" checked/></div><div class="pcell"><input type="checkbox" checked/></div>
            <div class="pmod">Roles y permisos</div><div class="pcell"><input type="checkbox" checked/></div><div class="pcell"><input type="checkbox" checked/></div><div class="pcell"><input type="checkbox" checked/></div><div class="pcell"><input type="checkbox" checked/></div>
          </div>
          <button class="btn btn-primary" style="margin-top:14px;"><i class="ti ti-check"></i> Guardar cambios de permisos</button>
        </div>
        <div class="card">
          <div class="card-header"><span class="card-title">Empleados registrados</span></div>
          <table>
            <thead><tr><th>Nombre</th><th>Cargo</th><th>Tipo</th><th>Estado</th></tr></thead>
            <tbody>
              <tr><td>Alejandra Pérez</td><td>Administrador</td><td>Tiempo completo</td><td><span class="status-dot" style="background:#10b981;"></span>Activo</td></tr>
              <tr><td>Ximena León</td><td>Responsable de bodega</td><td>Tiempo completo</td><td><span class="status-dot" style="background:#10b981;"></span>Activo</td></tr>
              <tr><td>Carlos López</td><td>Coordinador de eventos</td><td>Medio tiempo</td><td><span class="status-dot" style="background:#ef4444;"></span>Inactivo</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.sidebar .nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  const keys = ['cotizacion','costos','abonos','roles'];
  const items = document.querySelectorAll('.sidebar .nav-item');
  const i = keys.indexOf(id);
  if (i >= 0) items[i].classList.add('active');
}

function fmt(n) {
  return '$' + Math.round(n).toLocaleString('es-CO');
}

function calcCotizacion() {
  const boxes = document.querySelectorAll('#page-cotizacion .service-row input[type="checkbox"]');
  let sub = 0;
  boxes.forEach(b => { if (b.checked) sub += parseFloat(b.dataset.price); });
  const descPct = parseFloat(document.getElementById('descuento').value) || 0;
  const desc = sub * (descPct / 100);
  const baseAfterDesc = sub - desc;
  const iva = baseAfterDesc * 0.19;
  const total = baseAfterDesc + iva;
  document.getElementById('sub-cot').textContent = fmt(sub);
  document.getElementById('desc-cot').textContent = '-' + fmt(desc);
  document.getElementById('iva-cot').textContent = fmt(iva);
  document.getElementById('total-cot').textContent = fmt(total);
}

function calcCosto() {
  const valorPaquete = parseFloat(document.getElementById('valorPaquete').value) || 0;
  const numInv = parseFloat(document.getElementById('numInv').value) || 0;
  const addDJ = parseFloat(document.getElementById('addDJ').value) || 0;
  const addLuces = parseFloat(document.getElementById('addLuces').value) || 0;
  const abonos = parseFloat(document.getElementById('totalAbonos').value) || 0;
  const paquete = valorPaquete * numInv;
  const adicionales = addDJ + addLuces;
  const subtotal = paquete + adicionales;
  const saldo = subtotal - abonos;
  document.getElementById('costo-paquete').textContent = fmt(paquete);
  document.getElementById('costo-adic').textContent = fmt(adicionales);
  document.getElementById('costo-subtotal').textContent = fmt(subtotal);
  document.getElementById('costo-abonos').textContent = '-' + fmt(abonos);
  document.getElementById('costo-saldo').textContent = fmt(saldo);
}

function selectRole(el, name) {
  document.querySelectorAll('.role-pill').forEach(p => p.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('rol-actual').textContent = name;
}

function toggleEstado() {
  const val = document.getElementById('estadoEmpleado').value;
  const alertBox = document.getElementById('estado-alert');
  const grid = document.getElementById('permGrid');
  if (val === 'Inactivo') {
    alertBox.style.display = 'flex';
    grid.style.opacity = '0.4';
    grid.style.pointerEvents = 'none';
  } else {
    alertBox.style.display = 'none';
    grid.style.opacity = '1';
    grid.style.pointerEvents = 'auto';
  }
}

calcCotizacion();
calcCosto();
</script>
</body>
</html>
